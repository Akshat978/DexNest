{
  "name": "@dexnest/desktop",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"vite build --config vite.main.config.ts --watch\" \"wait-on http://127.0.0.1:5173 dist/main/main.cjs dist/main/preload.cjs && electron .\"",
    "build": "vite build --config vite.main.config.ts && vite build",
    "package:win": "corepack pnpm build && electron-builder --win --dir",
    "package:win:folder": "corepack pnpm build && electron-builder --win --dir",
    "package:win:installer": "corepack pnpm build && electron-builder --win nsis",
    "package:win:all": "corepack pnpm build && electron-builder --win",
    "dist:win": "corepack pnpm build && electron-builder --win",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "build": {
    "appId": "com.dexnest.desktop",
    "productName": "DexNest",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!local-data/**/*",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/tray.ico",
        "to": "tray.ico"
      },
      {
        "from": "../../sidecars",
        "to": "sidecars",
        "filter": [
          "**/*.py",
          "wake-word/models/**",
          "!**/.venv/**",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DexNest",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@dexnest/action-registry": "workspace:*",
    "@dexnest/local-db": "workspace:*",
    "@dexnest/module-command": "workspace:*",
    "@dexnest/module-deck": "workspace:*",
    "@dexnest/module-dev": "workspace:*",
    "@dexnest/shared-types": "workspace:*",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.9.1",
    "clsx": "^2",
    "framer-motion": "^11",
    "jimp": "^1.6.1",
    "lucide-react": "^0.516",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2",
    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10",
    "concurrently": "^9.1.2",
    "electron": "^35.1.4",
    "electron-builder": "^26.15.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.2.3",
    "wait-on": "^8.0.3"
  }
}
